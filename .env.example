# PostgreSQL (используется docker-compose.yml и приложением)
POSTGRES_USER=steam_analyzer
POSTGRES_PASSWORD=changeme
POSTGRES_DB=steam_analyzer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Steam Web API — ключ получить на https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Cookie steamLoginSecure залогиненной сессии — только для РАЗОВОГО ручного backfill
# истории цен через pricehistory (scripts/backfill_price_history.py).
# Достать: залогиниться на steamcommunity.com -> DevTools -> Application/Storage -> Cookies.
# Не для постоянной автоматизации.
STEAM_SESSION_COOKIE=

# Telegram-бот — токен получить у @BotFather
TELEGRAM_BOT_TOKEN=
